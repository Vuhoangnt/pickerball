<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="6dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="?attr/actionBarSize"
                android:background="@android:color/transparent"
                android:paddingTop="4dp"
                app:contentInsetEndWithActions="72dp"
                app:subtitleTextAppearance="@style/TextAppearance.Staff.Toolbar.Subtitle"
                app:titleTextAppearance="@style/TextAppearance.Staff.Toolbar.Title"
                app:subtitleTextColor="#E0FFFFFF"
                app:titleTextColor="@color/white"
                tools:title="@string/staff_appbar_title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.03"
                android:lineSpacingMultiplier="1.15"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:text="@string/staff_appbar_sub"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_staff_bottom_nav"
        android:elevation="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:itemHorizontalTranslationEnabled="false"
        app:itemIconSize="24dp"
        app:itemRippleColor="@color/outline_soft"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_staff" />
</LinearLayout>
