<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="@dimen/padding_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="0.01"
            android:text="Đặt sân"
            android:textColor="@color/text_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="Chọn ngày, giờ bắt đầu và giờ kết thúc — tiền sân tính theo đơn giá mỗi giờ × thời lượng (admin cấu hình giá sân và bảng giá khung giờ)."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="@dimen/radius_card_large"
            app:cardElevation="3dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Sân &amp; ngày"
                        android:textColor="@color/text_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerSan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:minHeight="52dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        tools:text="Ngày: 2025-03-26" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickDate"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đổi ngày"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="@dimen/radius_card_large"
            app:cardElevation="3dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Thời gian đặt"
                        android:textColor="@color/text_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSanOpenHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Giờ mở cửa sân: 06:00 – 22:00" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Khung giờ đã đặt"
                    android:textColor="@color/text_title"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBookedSlots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@color/brand_blue_light"
                    android:lineSpacingExtra="3dp"
                    android:padding="10dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="- 08:00 - 09:30&#10;- 10:00 - 11:00" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleSlotTable"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Xem bảng khung giờ"
                    android:textAllCaps="false"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/arrow_down_float"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSlotTable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvSelectedSlotSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@color/theme_forest_container"
                    android:padding="10dp"
                    android:text="Đang chọn: chưa có"
                    android:textColor="@color/theme_forest_on_container"
                    android:textSize="13sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGioBatDau"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="52dp"
                        android:text="Giờ bắt đầu"
                        android:textAllCaps="false"
                        app:cornerRadius="14dp"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="?attr/colorPrimary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGioKetThuc"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:minHeight="52dp"
                        android:text="Giờ kết thúc"
                        android:textAllCaps="false"
                        app:cornerRadius="14dp"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="?attr/colorPrimary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBookingDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Thời lượng: 1 giờ 30 phút" />

                <TextView
                    android:id="@+id/tvGiaGioRef"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Đơn giá tham chiếu: 150.000 đ/giờ (theo cấu hình sân / khung giờ)" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="@dimen/radius_card_large"
            app:cardElevation="2dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="Dịch vụ (tuỳ chọn)"
                        android:textColor="@color/text_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDvPick"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="@dimen/radius_card_large"
            app:cardElevation="3dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Tổng tiền dự kiến: 200.000 đ" />

                <TextView
                    android:id="@+id/tvSanOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Tiền sân: …" />

                <TextView
                    android:id="@+id/tvDvOnly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    tools:text="Tiền dịch vụ: …" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Ghi chú"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_card"
                    app:boxCornerRadiusBottomStart="@dimen/radius_card"
                    app:boxCornerRadiusTopEnd="@dimen/radius_card"
                    app:boxCornerRadiusTopStart="@dimen/radius_card">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBook"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:minHeight="54dp"
                    android:text="Gửi yêu cầu đặt sân"
                    android:textSize="15sp"
                    app:cornerRadius="26dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
